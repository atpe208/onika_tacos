      "isDeleted": false,
      "boundElements": null,
      "updated": 1774118686782,
      "link": null,
      "locked": false,
      "text": "Quiere lo mejor para el Furro-\nEstado mexicano, motivado por\nperder a su jefa taquera, por culpa\nde la poli corrupta",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Quiere lo mejor para el Furro-Estado mexicano, motivado por perder a su jefa taquera, por culpa de la poli corrupta",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "Z1pTbzG3Ow6stPyYqUphn",
      "type": "text",
      "x": 8.93980352263361,
      "y": 343.62598662819585,
      "width": 248.6552734375,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ef3e4f",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "GBcSlSA32anrrlB7-2Qk1",
      "index": "b3W",
      "roundness": null,
      "seed": 1936201207,
      "version": 387,
      "versionNonce": 505010553,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1774118708044,
      "link": null,
      "locked": false,
      "text": "Derrocar a los corruptos del\nFurro-Estado mexicano,\nquitando a los corruptos del\npoder y vengando a su anciana\njefa",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Derrocar a los corruptos del Furro-Estado mexicano, quitando a los corruptos del poder y vengando a su anciana jefa",
      "autoResize": false,
      "lineHeight": 1.25
    },
